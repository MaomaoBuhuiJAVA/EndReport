# Vercel Postgres / Neon / Supabase PostgreSQL URL.
# In Vercel, map DATABASE_URL to the Postgres connection string.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"

# Server-side only. Never expose this with NEXT_PUBLIC_.
DEEPSEEK_API_KEY="your_deepseek_api_key_here"

# Optional: set if you want to switch endpoints later.
DEEPSEEK_API_URL="https://api.deepseek.com/chat/completions"
